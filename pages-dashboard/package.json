{
  "name": "workerflow-pages-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "vite preview",
    "release:check": "npm run lint && npm run test && npm run build",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name workerflow-dashboard"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "7.1.0-canary-e0cc7202-20260227",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.0",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "flatted": "^3.4.1",
    "undici": "^7.24.3"
  }
}
